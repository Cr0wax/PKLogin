{
  "name": "pklogin",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:backend dev:frontend",
    "dev:backend": "npm --workspace apps/backend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "build": "npm run -ws build",
    "test": "npm run -ws test",
    "lint": "npm run -ws lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
